# ══════════════════════════════════════════════════════════════════════════════
#  OSM Scheduler — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════

# ── Admin Credentials ─────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=admin123

# ── C# Backend API ────────────────────────────────────────────────────────────
# Base URL of the C# API (no trailing slash)
CSHARP_API_BASE=http://103.68.40.77

# ── Base URL (optional, for reverse-proxy / sub-path deployments) ─────────────
# Leave empty if the app runs at root ( / )
BASE_URL=/osmmicroservices

# ══════════════════════════════════════════════════════════════════════════════
#  PostgreSQL Database
# ══════════════════════════════════════════════════════════════════════════════
# These are used as defaults; the dashboard /api/test-db endpoint can override
# them at runtime.
DB_HOST=103.68.40.77
DB_PORT=5432
DB_NAME=OSM
DB_USER=postgres
DB_PASSWORD=osm@123

# ══════════════════════════════════════════════════════════════════════════════
#  Scheduler Intervals
# ══════════════════════════════════════════════════════════════════════════════
# Snooze check interval (seconds)
SNOOZE_INTERVAL=5

# PM + AMC scheduler interval (seconds) — default 300 = 5 minutes
PM_AMC_INTERVAL=300

# ══════════════════════════════════════════════════════════════════════════════
#  Logging
# ══════════════════════════════════════════════════════════════════════════════
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Max size per log file (bytes) — default 5 MB
LOG_MAX_BYTES=5242880

# Number of rotating backup log files to keep
LOG_BACKUP_COUNT=5